rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // 租賃契約附件：保留原本租賃系統使用路徑。
    match /rental-contracts/{contractId}/{fileName=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 5242880
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf' || request.resource.contentType == 'text/html');
    }

    // 外聘老師簽約附件：身分證浮水印圖、簽名圖、契約 HTML。
    match /external-teachers/{contractId}/{fileName=**} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 5242880
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf' || request.resource.contentType == 'text/html');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
